# ======================
# DATABASE CONFIGURATION
# ======================
DATABASE_URL="postgresql://leubok_user:leubok_password@localhost:5432/leubok_db"
DATABASE_SHADOW_URL="postgresql://leubok_user:leubok_password@localhost:5432/leubok_shadow_db"

# ======================
# BACKEND CONFIGURATION
# ======================
BACKEND_PORT=3500
BACKEND_URL=http://localhost:3500
NODE_ENV=development

# ======================
# JWT CONFIGURATION
# ======================
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRY=7d

# ======================
# BLOCKCHAIN CONFIGURATION
# ======================
COSMOS_CHAIN_ID=theta-testnet-001
COSMOS_RPC_URL=https://rpc.sentry-01.theta-testnet.polypore.xyz
COSMOS_REST_URL=https://rest.sentry-01.theta-testnet.polypore.xyz
COSMOS_DENOM=uatom
USMC_CONTRACT_ADDRESS=cosmos1contract_address_here
ESCROW_CONTRACT_ADDRESS=cosmos1escrow_contract_address_here
REPUTATION_CONTRACT_ADDRESS=cosmos1reputation_contract_address_here

# ======================
# USDC CONFIGURATION
# ======================
USDC_CONTRACT_ADDRESS=cosmos1usdc_contract_address
USDC_DECIMALS=6
PLATFORM_FEE_PERCENTAGE=2.5
ESCROW_FEE_PERCENTAGE=0.5

# ======================
# STORAGE CONFIGURATION
# ======================
IPFS_API_KEY=your_ipfs_api_key
IPFS_GATEWAY_URL=https://gateway.pinata.cloud
ARWEAVE_KEY_FILE=./arweave_key.json
MAX_FILE_SIZE=52428800

# ======================
# AI CONFIGURATION
# ======================
OPENAI_API_KEY=sk-your_openai_api_key_here
OPENAI_MODEL=gpt-4-turbo
CLAUDE_API_KEY=sk-ant-your_claude_api_key_here

# ======================
# EMAIL CONFIGURATION
# ======================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=noreply@leubok.com

# ======================
# PAYMENT CONFIGURATION
# ======================
MIN_PAYMENT_AMOUNT=1
MAX_PAYMENT_AMOUNT=1000000
PAYMENT_TIMEOUT_MINUTES=30

# ======================
# ADMIN CONFIGURATION
# ======================
ADMIN_EMAIL=admin@leubok.com
ADMIN_SECRET_KEY=your_admin_secret_key

# ======================
# FRONTEND CONFIGURATION
# ======================
NEXT_PUBLIC_BACKEND_URL=http://localhost:3500
NEXT_PUBLIC_CHAIN_ID=theta-testnet-001
NEXT_PUBLIC_RPC_URL=https://rpc.sentry-01.theta-testnet.polypore.xyz
NEXT_PUBLIC_REST_URL=https://rest.sentry-01.theta-testnet.polypore.xyz

# ======================
# LOGGING
# ======================
LOG_LEVEL=debug
LOG_FORMAT=json

# ======================
# CORS CONFIGURATION
# ======================
CORS_ORIGIN=http://localhost:3000,http://localhost:3001

# ======================
# RATE LIMITING
# ======================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
